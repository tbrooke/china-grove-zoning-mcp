  "infill_lot_rule": {
    "applies_to": "ALL zoning districts",
    "ordinance_sections": ["2.2D", "7 (Dimensional Standards Table footnote)"],
    "rule": "Front and side yard setbacks for infill lot development shall be equal to the average for similar principal structures on the same side of the street and within the same zoning district within 300 feet of either side of the lot in question.",
    "effect": "Overrides standard front and side setbacks when the lot qualifies as infill development. Does not modify rear setbacks, density, height, or lot size minimums.",
    "calculation_note": "Requires measuring actual front and side setbacks of similar structures within 300 ft on the same street side and same zoning district. Building footprint data or site survey typically needed."
  },
  "notes": {
    "accessory_general": "No accessory building shall be erected in any front or side yard. The total area of all accessory structures shall not exceed 1/2 the gross floor area of the principal structure."
  }
}
